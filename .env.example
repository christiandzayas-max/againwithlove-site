# ──────────────────────────────────────────────────────────────
# Again, With Love — environment variables
# Copy this file to `.env.local` for local development.
# In production, set these in the Vercel project settings.
#
# NOTE: NEXT_PUBLIC_* vars are baked in at BUILD time. Changing one in
# Vercel requires a fresh redeploy, not just a save.
# ──────────────────────────────────────────────────────────────

# Canonical public site URL (used for metadata / Open Graph / sitemap / robots).
# Must match the host the live domain actually resolves to AFTER any
# apex<->www redirect. Verify the redirect direction before trusting this.
NEXT_PUBLIC_SITE_URL=https://againwithlove.com
